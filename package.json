{
    "version": "1.21.0",
    "name": "@hcvp/pocketbase-js",
    "description": "PocketBase JavaScript SDK",
    "author": "H.C. van Pelt",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git://github.com/crisvp/pocketbase-js.git"
    },
    "exports": {
        ".": {
            "import": "./dist/pocketbase-js.mjs",
            "require": "./dist/pocketbase-js.js",
            "types": "./dist/pocketbase-js.d.ts"
        }
    },
    "module": "./dist/pocketbase-js.mjs",
    "types": "./dist/pocketbase-js.d.ts",
    "keywords": [
        "pocketbase",
        "pocketbase-js",
        "js-sdk",
        "javascript-sdk",
        "pocketbase-sdk"
    ],
    "scripts": {
        "build": "vite build",
        "compile": "tsc -p .",
        "test": "vitest"
    },
    "prettier": {
        "editorconfig": true,
        "tabWidth": 4,
        "printWidth": 120,
        "bracketSameLine": true
    },
    "devDependencies": {
        "@types/node": "^20.14.2",
        "browserslist-to-esbuild": "^2.1.1",
        "prettier": "3.2.4",
        "rollup": "^3.0.0",
        "rollup-plugin-ts": "^3.0.0",
        "typescript": "^5.1.6",
        "vite-plugin-dts": "^3.9.1",
        "vitest": "^0.34.1"
    },
    "dependencies": {
        "vite": "^5.2.12"
    }
}
